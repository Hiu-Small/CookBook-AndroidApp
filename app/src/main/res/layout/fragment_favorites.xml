<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
             android:layout_height="match_parent">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="My Favorites ❤️"
        android:textColor="#2B2D42"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSortBy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Sort by:"
        android:textColor="#8C919E"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="@+id/btnSortNewest"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnSortNewest" />

    <Button
        android:id="@+id/btnSortNewest"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:text="Newest"
        android:textAllCaps="false"
        android:textSize="13sp"
        app:backgroundTint="#2B2D42"
        app:cornerRadius="20dp"
        app:layout_constraintStart_toEndOf="@+id/tvSortBy"
        app:layout_constraintTop_toBottomOf="@+id/tvSavedCount" />

    <Button
        android:id="@+id/btnSortAZ"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_marginStart="8dp"
        android:backgroundTint="#FFC107"
        android:text="A → Z"
        android:textAllCaps="false"
        android:textColor="#8C919E"
        android:textSize="13sp"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="@+id/btnSortNewest"
        app:layout_constraintStart_toEndOf="@+id/btnSortNewest"
        app:layout_constraintTop_toTopOf="@+id/btnSortNewest"
        app:layout_constraintVertical_bias="0.0"
        app:strokeColor="#E0E0E0" />

    <TextView
        android:id="@+id/tvSavedCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:text="4 saved recipes"
        android:textColor="#8C919E"
        android:textSize="15sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFavorites"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2"
        tools:listitem="@layout/item_recipe_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnSortNewest" />

</androidx.constraintlayout.widget.ConstraintLayout>